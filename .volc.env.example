# 火山方舟 OpenAPI 凭证（用于桌面组件读取云端套餐用量）
#
# 用法：
#   1. 复制本文件为 .volc.env ：cp .volc.env.example .volc.env
#   2. 填入你自己的凭证（下方 VOLC_AK_ID / VOLC_AK_SECRET）
#
# 获取方式：登录火山引擎控制台 -> 方舟(OpenAPI) -> 创建 AccessKey。
#
# 安全提示：
#   .volc.env 含敏感凭证，已在 .gitignore 中忽略，请勿提交到版本库或外发。
#   组件也可在不配置凭证的情况下运行——此时本地 token 用量照常展示，
#   仅「云端套餐用量」区块会自动隐藏。

VOLC_AK_ID=
VOLC_AK_SECRET=

# 套餐类型：选择你开通的火山方舟套餐，决定组件调哪个接口取额度。
#   coding = 编程套餐（GetCodingPlanUsage，只返回百分比，默认）
#   agent  = 旧版 AgentPlan 智能体套餐（GetAFPUsage，返回绝对额度）
# 不填则默认 coding。
VOLC_PLAN_TYPE=coding

# 套餐档位（可选）：火山接口不返回档位（Pro/标准版/Max…），由你自行标注，
# 组件会在 badge 显示成"编程套餐·Pro"。留空则只显示"编程套餐"。
VOLC_PLAN_TIER=Pro
